          },
          "editorMode": "code",
          "expr": "sum by (status, label, team) (increase(latr_rotations_total{__LATR_SELECTOR__,label=~\"$token_label\"}[$__rate_interval]))",
          "legendFormat": "{{team}}/{{label}} {{status}}",
          "range": true,
          "refId": "A"
        }
